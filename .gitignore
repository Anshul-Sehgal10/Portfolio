# Monorepo ignores

# Node dependencies
**/node_modules/

# Build outputs
**/.next/
**/dist/
**/build/
**/out/

# Logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# Environment files
**/.env
**/.env.*
!.env.example

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# TypeScript cache
**/*.tsbuildinfo

# Runtime lock persistence and temp files
backend/data/locks.json
backend/data/*.tmp

# Ignore all files in the backend/data directory 
backend/data/*
